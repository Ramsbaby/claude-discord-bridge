# Jarvis .env 설정 파일
# 복사 후 값 채우기: cp .env.example .env

# ===== 필수 =====
DISCORD_TOKEN=your_discord_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===== Discord 서버 설정 =====
# 슬래시 커맨드 등록 대상 서버 ID
GUILD_ID=your_discord_guild_id
# 봇이 응답할 채널 ID (쉼표 구분, 공백 없이)
CHANNEL_IDS=channel_id1,channel_id2
# 재시작 알림 제외 채널 ID (쉼표 구분, 선택)
QUIET_CHANNEL_IDS=

# ===== Discord 사용자 설정 =====
# 오너 Discord 사용자 ID (권한 체크 — 반드시 입력)
OWNER_DISCORD_ID=your_discord_user_id
# 아내 Discord 사용자 ID (선택)
BORAM_DISCORD_ID=

# ===== 봇 페르소나 설정 =====
# 봇 이름 (시스템 프롬프트·로그에 사용)
BOT_NAME=Jarvis
# 응답 로케일 (ko / en)
BOT_LOCALE=ko
# 오너 이름 (시스템 프롬프트에 사용)
OWNER_NAME=Owner
# 오너 직함 (시스템 프롬프트에 사용)
OWNER_TITLE=Owner
# GitHub 사용자명 (Owner Context에 표시)
GITHUB_USERNAME=

# ===== 알림 채널 설정 =====
# 오너 전용 알림 채널 ID (선택)
OWNER_ALERT_CHANNEL_ID=

# ===== 알림 서비스 (선택) =====
# ntfy 서버 URL
NTFY_SERVER=https://ntfy.sh
# ntfy 토픽명 (비어 있으면 알림 비활성화)
NTFY_TOPIC=

# ===== 외부 서비스 (선택) =====
# OpenAI API 키 (Discord 음성 메시지 Whisper 변환용)
OPENAI_API_KEY=
# claude 실행 파일 경로 (기본: ~/.local/bin/claude)
CLAUDE_BINARY=

# ===== 기타 =====
# Docker 기본값. 로컬 실행 시 제거해도 됨
JARVIS_HOME=/jarvis
# Claude CLI 인증 경로 — setup.ps1/setup.sh가 자동 설정. 수동 지정 시 아래 주석 해제
# macOS/Linux: CLAUDE_HOME=/Users/yourname  |  Windows: CLAUDE_HOME=C:/Users/yourname
# CLAUDE_HOME=
NODE_ENV=production

# Google Calendar (선택)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Discord 채널 IDs (레거시 — CHANNEL_IDS로 대체됨)
DISCORD_CHANNEL_JARVIS_CEO=
DISCORD_CHANNEL_JARVIS_DEV=
