# Jarvis .env 설정 파일
# 복사 후 값 채우기: cp .env.example .env

# ===== 필수 =====
DISCORD_TOKEN=your_discord_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===== 선택 =====
JARVIS_HOME=/jarvis          # Docker 기본값. 로컬 실행 시 제거해도 됨
NODE_ENV=production

# Google Calendar (선택)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Discord 채널 IDs
DISCORD_CHANNEL_JARVIS_CEO=
DISCORD_CHANNEL_JARVIS_DEV=
