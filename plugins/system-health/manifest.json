{
  "id": "system-health",
  "name": "System Health Check",
  "version": "1.2.0",
  "description": "Periodic system health check — disk, memory, CPU, key processes, cron failures",
  "schedule": "*/60 * * * *",
  "model": "claude-haiku-4-5-20251001",
  "prompt_file": "system-health.md",
  "prompt": "시스템 헬스체크: 디스크/메모리/CPU/프로세스/크론 실패 확인 후 이상 시 경고 출력",
  "resultMaxChars": 500,
  "allowedTools": "Bash",
  "output": ["file"],
  "discordChannel": "jarvis-system",
  "timeout": 300,
  "retry": {
    "max": 1,
    "backoff": "exponential"
  },
  "maxBudget": "0.50",
  "priority": "daily",
  "depends": [],
  "contextBudget": "small",
  "resultRetention": 1,
  "resultMaxChars": 500,
  "event_trigger": "system.alert",
  "event_trigger_debounce_s": 300,
  "tags": ["lite", "infra", "monitoring"]
}
