{
  "_comment": "6 generic starter tasks. Copy to tasks.json and customize. See docs/tasks-reference.md for all fields.",
  "_model_options": "claude-haiku-4-5-20251001 (fast+cheap) | claude-sonnet-4-6 (balanced) | claude-opus-4-6 (complex analysis)",
  "tasks": [
    {
      "id": "system-health",
      "name": "System Health Check",
      "schedule": "1,31 * * * *",
      "timeout": 60,
      "prompt": "Check system health: disk usage (alert if >85%), memory, top 5 processes by CPU. Output one-line summary.",
      "allowedTools": "Bash",
      "output": ["file"],
      "model": "claude-haiku-4-5-20251001",
      "retry": { "max": 2, "backoff": "linear" },
      "maxBudget": "0.10",
      "priority": "monitoring",
      "resultRetention": 3,
      "resultMaxChars": 300
    },
    {
      "id": "disk-alert",
      "name": "Disk Space Alert",
      "schedule": "*/15 * * * *",
      "timeout": 30,
      "prompt": "Run: df -h /. If usage is above 85%, send a Discord alert. Otherwise, do nothing and output 'OK'.",
      "allowedTools": "Bash",
      "output": ["discord", "file"],
      "discordChannel": "ai-bot",
      "model": "claude-haiku-4-5-20251001",
      "retry": { "max": 1, "backoff": "linear" },
      "maxBudget": "0.05",
      "priority": "monitoring",
      "resultRetention": 1,
      "resultMaxChars": 200
    },
    {
      "id": "memory-cleanup",
      "name": "Weekly Cleanup",
      "schedule": "0 3 * * 0",
      "timeout": 120,
      "prompt": "Clean up old files: 1) Remove logs older than 30 days from ~/.jarvis/logs/ 2) Clear tmp files 3) Report freed space.",
      "allowedTools": "Bash",
      "output": ["file"],
      "model": "claude-haiku-4-5-20251001",
      "retry": { "max": 1, "backoff": "linear" },
      "maxBudget": "0.10",
      "priority": "maintenance",
      "resultRetention": 7,
      "resultMaxChars": 500
    },
    {
      "id": "rag-health",
      "name": "RAG Index Health",
      "schedule": "0 6 * * *",
      "timeout": 90,
      "prompt": "Check RAG index: 1) Count documents in ~/.jarvis/state/lancedb/ 2) Verify last index time 3) Alert if index is stale (>24h).",
      "allowedTools": "Bash",
      "output": ["file"],
      "model": "claude-haiku-4-5-20251001",
      "retry": { "max": 2, "backoff": "linear" },
      "maxBudget": "0.10",
      "priority": "monitoring",
      "resultRetention": 7,
      "resultMaxChars": 400
    },
    {
      "id": "security-scan",
      "name": "Weekly Security Scan",
      "schedule": "0 4 * * 1",
      "timeout": 120,
      "prompt": "Security check: 1) Find world-writable files in ~/.jarvis/ 2) Check for .env files accidentally in git (git status) 3) Verify SSH config has PasswordAuthentication no. Report any issues.",
      "allowedTools": "Bash",
      "output": ["discord", "file"],
      "discordChannel": "ai-bot",
      "model": "claude-sonnet-4-6",
      "retry": { "max": 2, "backoff": "exponential" },
      "maxBudget": "0.50",
      "priority": "security",
      "resultRetention": 30,
      "resultMaxChars": 1000
    },
    {
      "id": "weekly-code-review",
      "name": "Weekly Code Review",
      "schedule": "0 9 * * 1",
      "timeout": 300,
      "prompt": "Weekly code quality check: 1) Run shellcheck on all .sh files in ~/.jarvis/bin/ and ~/.jarvis/scripts/ 2) Show git log --oneline from last 7 days 3) Flag any TODO/FIXME/HACK comments added this week.",
      "allowedTools": "Bash",
      "output": ["discord", "file"],
      "discordChannel": "ai-bot",
      "model": "claude-sonnet-4-6",
      "retry": { "max": 2, "backoff": "exponential" },
      "maxBudget": "0.50",
      "priority": "quality",
      "resultRetention": 30,
      "resultMaxChars": 2000
    }
  ]
}
